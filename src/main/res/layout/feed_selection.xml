<androidx.constraintlayout.widget.ConstraintLayout
		xmlns:android="http://schemas.android.com/apk/res/android"
		android:layout_width="match_parent"
		android:layout_height="match_parent"
		xmlns:app="http://schemas.android.com/apk/res-auto"
		xmlns:tools="http://schemas.android.com/tools">

	<LinearLayout
			android:id="@+id/feed_selection_textbox_top_layout"
			android:layout_width="match_parent"
			android:layout_height="wrap_content"
			app:layout_constraintTop_toTopOf="parent"
			app:layout_constraintLeft_toLeftOf="parent"
			app:layout_constraintRight_toRightOf="parent"
			android:padding="10dp"
			android:orientation="vertical">

		<Spinner
				android:id="@+id/feed_selection_account"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:layout_marginTop="2dp"
				android:layout_marginBottom="2dp"
				tools:listitem="@android:layout/simple_list_item_1"/>

		<EditText
				android:id="@+id/feed_selection_textbox"
				android:layout_width="match_parent"
				android:layout_height="wrap_content"
				android:importantForAutofill="no"
				android:singleLine="true"
				android:scrollHorizontally="true"
				android:hint="@string/feed_selection_textbox_hint"
				android:inputType="textNoSuggestions"/>

		<androidx.constraintlayout.widget.ConstraintLayout
				android:layout_width="match_parent"
				android:layout_height="wrap_content">

			<Button
					android:id="@+id/feed_selection_button_continue"
					android:layout_width="wrap_content"
					android:layout_height="wrap_content"
					app:layout_constraintEnd_toEndOf="parent"
					app:layout_constraintTop_toTopOf="parent"
					app:layout_constraintBottom_toBottomOf="parent"
					android:text="@string/dialog_continue" />

		</androidx.constraintlayout.widget.ConstraintLayout>

	</LinearLayout>

	<androidx.recyclerview.widget.RecyclerView
			android:id="@+id/feed_selection_autocomplete"
			android:layout_width="match_parent"
			android:layout_height="0dp"
			tools:listitem="@layout/list_item_1_text"
			app:layout_constrainedHeight="true"
			app:layout_constraintTop_toBottomOf="@id/feed_selection_textbox_top_layout"
			app:layout_constraintBottom_toBottomOf="parent"
			app:layout_constraintLeft_toLeftOf="parent"
			app:layout_constraintRight_toRightOf="parent"/>

</androidx.constraintlayout.widget.ConstraintLayout>
